generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  password      String
  firstName     String
  lastName      String
  phone         String?
  avatar        String?
  role          Role       @default(OPERATOR)
  status        UserStatus @default(ACTIVE)
  lastLoginAt   DateTime?
  loginAttempts Int        @default(0)
  lockedUntil   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  auditLogs     AuditLog[]
  sessions      Session[]

  @@index([email])
  @@index([role])
  @@index([status])
  @@map("users")
}

model Session {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("sessions")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

enum Role {
  ADMIN
  OPERATOR
  TECHNICIAN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Vessel {
  id           String        @id @default(cuid())
  name         String
  fleetType    FleetType
  vesselType   String
  status       VesselStatus  @default(OPERATIVO)
  flag         String?       @default("Venezuela")
  yearBuilt    Int?
  grossTon     Float?
  length       Float?
  capacity     Float?
  capacityUnit String?
  captain      String?
  marineOnDuty String?
  homePort     String?
  imoNumber    String?       @unique
  matricula    String?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tankCapacityLiters Float?

  fuelReports        FuelReport[]
  maintenanceReports MaintenanceReport[]
  statusReports      StatusReport[]
  assignments        Assignment[]
  voyages            Voyage[]
  fuelLogs           FuelLog[]
  inventoryItems     InventoryItem[]
  maintenanceOrders  MaintenanceOrder[]
  complianceDocs     ComplianceDocument[]
  equipment          Equipment[]
  maintenancePrograms MaintenanceProgram[]
  dailyReports       DailyReport[]

  @@index([fleetType])
  @@index([status])
  @@map("vessels")
}

// ═══════ FASE 3 — PERSONAL Y TRIPULACION ═══════

model Employee {
  id              String           @id @default(cuid())
  firstName       String
  lastName        String
  nationalId      String           @unique
  nationality     String           @default("Venezolana")
  position        String
  seafarerBook    String?
  passportNumber  String?
  passportExpiry  DateTime?
  phone           String?
  email           String?
  address         String?
  birthDate       DateTime?
  status          EmployeeStatus   @default(ACTIVO)
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  certifications  Certification[]
  assignments     Assignment[]

  @@index([status])
  @@index([position])
  @@map("employees")
}

model Certification {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type        String
  name        String
  number      String?
  issuedBy    String
  issuedAt    DateTime
  expiresAt   DateTime
  fileUrl     String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([employeeId])
  @@index([expiresAt])
  @@map("certifications")
}

model Assignment {
  id          String           @id @default(cuid())
  employeeId  String
  employee    Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  vesselId    String
  vessel      Vessel           @relation(fields: [vesselId], references: [id], onDelete: Cascade)
  role        String
  startDate   DateTime
  endDate     DateTime?
  status      AssignmentStatus @default(ACTIVO)
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([employeeId])
  @@index([vesselId])
  @@index([status])
  @@map("assignments")
}

enum EmployeeStatus {
  ACTIVO
  INACTIVO
  LICENCIA
  VACACIONES
  RETIRADO
}

enum AssignmentStatus {
  ACTIVO
  COMPLETADO
  CANCELADO
}

model FuelReport {
  id          String   @id @default(cuid())
  vesselId    String
  vessel      Vessel   @relation(fields: [vesselId], references: [id], onDelete: Cascade)
  date        DateTime
  fuelLevel   Float
  fuelUnit    String   @default("litros")
  consumption Float?
  location    String?
  operator    String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([vesselId])
  @@index([date])
  @@map("fuel_reports")
}

model MaintenanceReport {
  id            String    @id @default(cuid())
  vesselId      String
  vessel        Vessel    @relation(fields: [vesselId], references: [id], onDelete: Cascade)
  date          DateTime
  type          String
  description   String
  technician    String?
  partsReplaced String?
  cost          Float?
  status        String    @default("PENDIENTE")
  nextScheduled DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([vesselId])
  @@index([date])
  @@map("maintenance_reports")
}

model StatusReport {
  id           String       @id @default(cuid())
  vesselId     String
  vessel       Vessel       @relation(fields: [vesselId], references: [id], onDelete: Cascade)
  date         DateTime
  location     String
  activity     String
  fuelLevel    Float?
  client       String?
  captain      String
  marineOnDuty String
  vesselStatus VesselStatus
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([vesselId])
  @@index([date])
  @@map("status_reports")
}

enum FleetType {
  PESADA
  LIVIANA
}

enum VesselStatus {
  OPERATIVO
  EN_TRANSITO
  ATRACADO
  MANTENIMIENTO
  INACTIVO
}

// ═══════ FASE 4 — OPERACIONES ═══════

model Voyage {
  id            String       @id @default(cuid())
  vesselId      String
  vessel        Vessel       @relation(fields: [vesselId], references: [id], onDelete: Cascade)
  voyageNumber  String       @unique
  origin        String
  destination   String
  departureAt   DateTime?
  arrivalAt     DateTime?
  status        VoyageStatus @default(PLANIFICADO)
  cargoType     String?
  cargoTons     Float?
  charterParty  String?
  clientId      String?
  client        Client?      @relation(fields: [clientId], references: [id])
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  fuelLogs       FuelLog[]
  cargoOps       CargoOperation[]

  @@index([vesselId])
  @@index([status])
  @@index([clientId])
  @@map("voyages")
}

model FuelLog {
  id              String   @id @default(cuid())
  vesselId        String
  vessel          Vessel   @relation(fields: [vesselId], references: [id], onDelete: Cascade)
  voyageId        String?
  voyage          Voyage?  @relation(fields: [voyageId], references: [id])
  date            DateTime
  fuelType        String   @default("MGO")
  operationAt     String
  bunkerReceived  Float?
  consumed        Float?
  rob             Float
  price           Float?
  supplier        String?
  bdn             String?
  reportedBy      String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([vesselId])
  @@index([voyageId])
  @@index([date])
  @@map("fuel_logs")
}

model InventoryItem {
  id          String   @id @default(cuid())
  vesselId    String
  vessel      Vessel   @relation(fields: [vesselId], references: [id], onDelete: Cascade)
  name        String
  category    String
  quantity    Int      @default(0)
  unit        String   @default("unidad")
  minStock    Int      @default(0)
  location    String?
  supplier    String?
  lastRestocked DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  movements   InventoryMovement[]

  @@unique([vesselId, name])
  @@index([vesselId])
  @@index([category])
  @@map("inventory_items")
}

model CargoOperation {
  id              String    @id @default(cuid())
  voyageId        String
  voyage          Voyage    @relation(fields: [voyageId], references: [id], onDelete: Cascade)
  operationType   String
  product         String
  quantityBL      Float
  quantityVEF     Float?
  temperature     Float?
  apiGravity      Float?
  waterContent    Float?
  terminal        String?
  startAt         DateTime
  endAt           DateTime?
  blNumber        String?
  status          String    @default("EN_PROCESO")
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([voyageId])
  @@map("cargo_operations")
}

enum VoyageStatus {
  PLANIFICADO
  EN_CURSO
  COMPLETADO
  CANCELADO
}

// ═══════ FASE 5 — CLIENTES, MANTENIMIENTO, COMPLIANCE ═══════

model Client {
  id        String   @id @default(cuid())
  name      String
  taxId     String   @unique
  type      String   @default("EMPRESA")
  country   String   @default("Venezuela")
  address   String?
  phone     String?
  email     String?
  contact   String?
  notes     String?
  status    String   @default("ACTIVO")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  voyages   Voyage[]

  @@index([type])
  @@index([status])
  @@map("clients")
}

model MaintenanceOrder {
  id            String    @id @default(cuid())
  vesselId      String
  vessel        Vessel    @relation(fields: [vesselId], references: [id], onDelete: Cascade)
  type          String
  description   String
  priority      String    @default("MEDIA")
  system        String
  dueDate       DateTime
  completedAt   DateTime?
  technician    String?
  spareParts    String?
  cost          Float?
  status        String    @default("PENDIENTE")
  // Corrective maintenance fields
  cause         String?
  rootCause     String?
  failureMode   String?
  actionTaken   String?
  downtimeHours Float?
  equipmentAffected String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([vesselId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@map("maintenance_orders")
}

model ComplianceDocument {
  id          String    @id @default(cuid())
  vesselId    String?
  vessel      Vessel?   @relation(fields: [vesselId], references: [id], onDelete: Cascade)
  employeeId  String?
  type        String
  name        String
  documentNumber String?
  issuedBy    String
  issuedAt    DateTime
  expiresAt   DateTime
  fileUrl     String?
  status      String    @default("VIGENTE")
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([vesselId])
  @@index([employeeId])
  @@index([expiresAt])
  @@index([type])
  @@map("compliance_documents")
}

// ═══════ EQUIPOS Y MAQUINARIA ═══════

model Equipment {
  id              String   @id @default(cuid())
  vesselId        String
  vessel          Vessel   @relation(fields: [vesselId], references: [id], onDelete: Cascade)
  name            String
  type            String   // MOTOR_PRINCIPAL, MOTOR_AUXILIAR, GENERADOR, BOMBA, COMPRESOR, WINCHE, GRUA, OTRO
  brand           String?
  model           String?
  serialNumber    String?
  currentHours    Float    @default(0)
  lastServiceAt   Float?   // hours reading at last service
  serviceInterval Float?   // hours between services
  status          String   @default("OPERATIVO") // OPERATIVO, REQUIERE_SERVICIO, FUERA_SERVICIO
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  hourLogs        EquipmentHourLog[]

  @@unique([vesselId, name])
  @@index([vesselId])
  @@index([type])
  @@map("equipment")
}

model EquipmentHourLog {
  id           String    @id @default(cuid())
  equipmentId  String
  equipment    Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  date         DateTime
  hoursReading Float
  hoursRun     Float?
  reportedBy   String?
  notes        String?
  createdAt    DateTime  @default(now())

  @@index([equipmentId])
  @@index([date])
  @@map("equipment_hour_logs")
}

// ═══════ PROGRAMAS DE MANTENIMIENTO PREVENTIVO ═══════

model MaintenanceProgram {
  id              String    @id @default(cuid())
  vesselId        String
  vessel          Vessel    @relation(fields: [vesselId], references: [id], onDelete: Cascade)
  name            String
  description     String
  system          String
  frequency       String    // DIARIO, SEMANAL, QUINCENAL, MENSUAL, TRIMESTRAL, SEMESTRAL, ANUAL, POR_HORAS
  frequencyHours  Float?    // if POR_HORAS
  lastExecuted    DateTime?
  nextDue         DateTime?
  tasks           String    // checklist items (newline separated)
  materials       String?   // required materials
  status          String    @default("ACTIVO") // ACTIVO, PAUSADO
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([vesselId])
  @@index([nextDue])
  @@index([status])
  @@map("maintenance_programs")
}

// ═══════ MOVIMIENTOS DE INVENTARIO ═══════

model InventoryMovement {
  id              String        @id @default(cuid())
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  type            String        // ENTRADA, SALIDA
  quantity        Int
  reason          String?
  reference       String?       // invoice, order number
  executedBy      String?
  date            DateTime      @default(now())
  notes           String?
  createdAt       DateTime      @default(now())

  @@index([inventoryItemId])
  @@index([date])
  @@index([type])
  @@map("inventory_movements")
}

// ═══════ REPORTES DIARIOS DE FLOTA ═══════

model DailyReport {
  id              String       @id @default(cuid())
  vesselId        String
  vessel          Vessel       @relation(fields: [vesselId], references: [id], onDelete: Cascade)
  date            DateTime
  client          String?
  activity        String
  location        String?
  captain         String
  marineOnDuty    String
  personnel       String?
  fuelLevelLiters Float?
  fuelPercentage  Float?
  vesselStatus    VesselStatus
  notes           String?
  createdBy       String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([vesselId])
  @@index([date])
  @@map("daily_reports")
}
