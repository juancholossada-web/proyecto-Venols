# ============================================================
# VENOLS ERP — Variables de Entorno
# Copia este archivo como .env y completa los valores reales
# NUNCA subas el .env real al repositorio
# ============================================================

# Base de Datos PostgreSQL
# Formato: postgresql://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_BD
DATABASE_URL="postgresql://postgres:TU_PASSWORD@localhost:5432/maritime_erp_db"

# JWT — Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="GENERA_UN_SECRET_DE_64_BYTES_ALEATORIOS_AQUI"
JWT_EXPIRES_IN="8h"

# bcrypt — 12 rondas en producción (no bajar de 10)
BCRYPT_ROUNDS=12

# Entorno
NODE_ENV="development"

# URL pública de la app
NEXT_PUBLIC_APP_URL="http://localhost:3000"
